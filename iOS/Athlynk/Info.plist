<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- DEV ONLY: the athlete app talks to the Django backend over plain HTTP on
	     http://localhost:8000. App Transport Security blocks cleartext by
	     default, so we open an exception scoped to localhost. Remove / tighten
	     before shipping a production build that hits an HTTPS host.

	     This file lives in the project root (NOT inside the Athlynk/ synchronized
	     group) so it is consumed only as INFOPLIST_FILE and never auto-added to
	     Copy Bundle Resources, which would cause "Multiple commands produce
	     Info.plist". -->
	<!-- Photo library: the modern PhotosPicker (PHPickerViewController) runs
	     out-of-process and needs no permission prompt, but we declare the usage
	     string anyway for App Review and any future direct-library access. -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Consenti l'accesso alle foto per impostare la tua immagine del profilo.</string>
	<!-- Allow the app to receive remote (APNs) push notifications. Inert until
	     the Push Notifications capability + APNs key are added to the target. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
